# .streamlit/secrets.toml.example
# Copy this to .streamlit/secrets.toml (NEVER commit secrets.toml to git)

SUPABASE_URL = "https://your-project.supabase.co"
SUPABASE_ANON_KEY = "your-anon-key-here"

[users.admin]
password_hash = "sha256-hash-of-your-password"   # generate with: python3 -c "import hashlib; print(hashlib.sha256('yourpassword'.encode()).hexdigest())"
role = "admin"

[users.staff1]
password_hash = "sha256-hash-here"
role = "staff"
